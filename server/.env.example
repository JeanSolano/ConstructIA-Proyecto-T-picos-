# Copia este archivo como `.env` y coloca tu propia clave.
# Obtener una clave gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_clave_de_gemini_aqui

# Modelo de Gemini. Se usa "gemini-flash-latest": es un alias que Google mantiene
# apuntando al modelo flash vigente, disponible para claves/proyectos nuevos.
# (No uses "gemini-2.5-flash": fue restringido y da 404 a usuarios nuevos.)
# Alternativa estable si ves errores 503 esporadicos: gemini-3.5-flash
GEMINI_MODEL=gemini-flash-latest

# Puerto del servidor.
PORT=3001
